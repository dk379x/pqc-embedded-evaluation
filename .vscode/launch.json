{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "cppdbg",
            "request": "launch",
            "name": "ESP32 JTAG Debug",
            "MIMode": "gdb",
            "targetArchitecture": "arm",
            "program": "${workspaceFolder}/build/hello_world.elf",
            "miDebuggerPath": "C:/Users/danie/.espressif/tools/xtensa-esp-elf-gdb/12.1_20231023/xtensa-esp-elf-gdb/bin/xtensa-esp32-elf-gdb.exe",
            "cwd": "${workspaceFolder}",
            "debugServerArgs": "-f interface/ftdi/esp32_devkitj_v1.cfg -f target/esp32.cfg",
            "serverStarted": "Info : Listening on port 3333 for gdb connections",
            "filterStderr": true,
            "filterStdout": false,
            "externalConsole": false,
            "setupCommands": [
                { "text": "target remote :3333" },
                { "text": "mon reset halt" },
                { "text": "mon init" },
                { "text": "flushregs" },
                { "text": "set remote hardware-breakpoint-limit 2" },
                { "text": "set remote hardware-watchpoint-limit 2" },
                { "text": "set pagination off" }
            ],
            "logging": {
                "engineLogging": true,
                "trace": true,
                "traceResponse": true
            }
        }
    ]
}
